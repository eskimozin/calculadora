{
  "name": "calculadora",
  "description": "Calculadora da subathon 2025 do eskimozin ",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node register.build.js && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint src/**/*.js src/**/*.jsx --fix",
    "preview": "vite preview",
    "deploy": "node register.build.js && vite build && gh-pages -d dist",
    "update": "npm update",
    "upgrade:deps": "npx npm-check-updates -i && npm install",
    "sync:version": "git pull && node scripts/sync-version.js && git add package.json && git commit -m \"build: update version\""
  },
  "dependencies": {
    "aos": "^2.3.4",
    "bootstrap": "^5.3.8",
    "framer-motion": "^12.42.2",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-number-format": "^5.4.5",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "vite": "^8.1.5"
  }
}